(define (Egg.Token.Int value)
  (unless (integer? value)
    (error 'Egg.Token.Int "Value must be an integer" value))
  (pipe (Egg.Object 'Egg.Token.Int)
	(curry Egg.Object.set ':value value)))
(define (Egg.Token.Int? v)
  (and (Egg.Object? v)
       (equal? (Egg.Object.getTag v)
	       'Egg.Token.Int)))

(define (Egg.Token.Int.getValue t)
  (unless (Egg.Token.Int? t)
    (error 'Egg.Token.Int.getValue "Not an Egg.Token.Int" t))
  (Egg.Object.get ':value #f t))
(define (Egg.Token.Int.setValue value t)
  (unless (Egg.Token.Int? t)
    (error 'Egg.Token.Int.setValue "Not an Egg.Token.Int" t))
  (unless (integer? value)
    (error 'Egg.Token.Int.setValue "Value must be an integer" value))
  (Egg.Object.set ':value value t))


