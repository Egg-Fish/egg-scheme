(define (Egg.Token? v)
  (or (Egg.Token.Let? v)
      (Egg.Token.In? v)
      (Egg.Token.Equal? v)
      (Egg.Token.Plus? v)
      (Egg.Token.Star? v)
      (Egg.Token.Dot? v)
      (Egg.Token.LP? v)
      (Egg.Token.RP? v)
      (Egg.Token.Int? v)
      (Egg.Token.Id? v)
      (Egg.Token.Lambda? v)
      (Egg.Token.Unknown? v)))


(define (Egg.Token.Let)
  (Egg.Object 'Egg.Token.Let))
(define (Egg.Token.Let? v)
  (and (Egg.Object? v)
       (equal? (Egg.Object.getTag v)
	       'Egg.Token.Let)))


