(define (Egg.Expr.Var name)
  (unless (string? name)
    (error 'Egg.Expr.Var "Name must be a string" name))
  (pipe (Egg.Object 'Egg.Expr.Var)
	(curry Egg.Object.set ':name name)))
(define (Egg.Expr.Var? v)
  (and (Egg.Object? v)
       (equal? (Egg.Object.getTag v)
	       'Egg.Expr.Var)))

(define (Egg.Expr.Var.getName e)
  (unless (Egg.Expr.Var? e)
    (error 'Egg.Expr.Var.getName "Not an Egg.Expr.Var" e))
  (Egg.Object.get ':name #f e))
(define (Egg.Expr.Var.setName name e)
  (unless (Egg.Expr.Var? e)
    (error 'Egg.Expr.Var.setName "Not an Egg.Expr.Var" e))
  (unless (string? name)
    (error 'Egg.Expr.Var.setName "Name must be a string" name))
