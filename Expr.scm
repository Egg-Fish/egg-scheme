(define (Egg.Expr.Int value)
  (unless (integer? value)
    (error 'Egg.Expr.Int "Value must be an integer" value))
  (pipe (Egg.Object 'Egg.Expr.Int)
	(curry Egg.Object.set ':value value)))
(define (Egg.Expr.Int? v)
  (and (Egg.Object? v)
       (equal? (Egg.Object.getTag v)
	       'Egg.Expr.Int)))

(define (Egg.Expr.Int.getValue e)
  (unless (Egg.Expr.Int? e)
    (error 'Egg.Expr.Int.getValue "Not an Egg.Expr.Int" e))
  (Egg.Object.get ':value #f e))
(define (Egg.Expr.Int.setValue value e)
  (unless (Egg.Expr.Int? e)
    (error 'Egg.Expr.Int.setValue "Not an Egg.Expr.Int" e))
  (unless (integer? value)
    (error 'Egg.Expr.Int.setValue "Value must be an integer" value))
  (Egg.Object.set ':value value e))


(define (Egg.Expr.Unknown)
  (Egg.Object 'Egg.Expr.Unknown))
(define (Egg.Expr.Unknown? v)
  (and (Egg.Object? v)
       (equal? (Egg.Object.getTag v)
	       'Egg.Expr.Unknown)))
